# === Telegram: Contact Checker account ===
CHECKER_API_ID=your_api_id_here
CHECKER_API_HASH=your_api_hash_here
CONTACT_CHECKER_SESSION=your_string_session_here

# === Telegram: Message Sender account (separate account recommended) ===
SENDER_API_ID=your_api_id_here
SENDER_API_HASH=your_api_hash_here
MESSAGE_SENDER_SESSION=your_string_session_here

# === Supabase ===
# Project Settings -> Data API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings -> API Keys -> service_role (secret, NOT the anon/publishable key)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === Google Sheet (only used by `--mode seed`, run once) ===
# Share the sheet as "Anyone with the link - Viewer", then build the CSV
# export URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/export?format=csv&gid={GID}
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/your_sheet_id/export?format=csv&gid=0
PHONE_COLUMN_INDEX=0

# === Processing configuration ===
BATCH_SIZE=50000
CHECK_DELAY_SECONDS=2
CHECKPOINT_INTERVAL=100
MAX_RUNTIME_SECONDS=18000
FLOOD_SLEEP_THRESHOLD=60

# 2-3 numbers you KNOW are on Telegram (your own, a close contact). Checked
# before every checkpoint - if none resolve, the checker account is likely
# restricted, and the run stops itself instead of mislabeling real numbers
# as not_found.
CANARY_PHONES=+959xxxxxxxxx,+959yyyyyyyyy

# === Sender configuration ===
# Message content now lives in Supabase (message_templates table), not here -
# see README. MIN_ACTIVITY_LEVEL is a threshold: it includes everything AT
# OR ABOVE the level named here. e.g. UserStatusLastWeek = Online + Recently
# + LastWeek. To add LastMonth later, just change this one value.
MESSAGE_BATCH_SIZE=1
MESSAGE_DELAY_MIN=10
MESSAGE_DELAY_MAX=30
MIN_ACTIVITY_LEVEL=UserStatusLastWeek
